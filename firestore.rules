rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if authorized admin account
    function isAdmin() {
      return isSignedIn() &&
             (request.auth.token.email == 'mahfujar003@gmail.com' || request.auth.token.email == 'sadhinultra@gmail.com');
    }

    // Public portfolio collections read permissions
    match /profile/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /skills/{skillId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /contacts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /photography/{photographyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
